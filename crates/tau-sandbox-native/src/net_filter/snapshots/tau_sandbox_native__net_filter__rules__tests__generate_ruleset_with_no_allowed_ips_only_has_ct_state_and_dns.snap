---
source: crates/tau-sandbox-native/src/net_filter/rules.rs
expression: ruleset
---
table inet tau_sandbox {
    chain output {
        type filter hook output priority 0; policy drop;
        ct state established,related accept
        udp dport 53 ip daddr 1.1.1.1 accept
        udp dport 53 ip daddr 8.8.8.8 accept
    }
}

